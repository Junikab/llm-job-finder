# Copy to .env at repo root
OPENAI_API_KEY=
PORT=5174
SCRAPER_HEADLESS=true
MAX_JOBS=40
MAX_PAGES=3
JORA_REGION=au

## Scoring mode: random | heuristic | llm
# default is random; llm currently falls back to heuristic until wired
SCORE_MODE=random

## LLM scaffolding (optional; rerank stub only for now)
# LLM_MODE: off | rerank | replace
LLM_MODE=off
# Top-N for rerank mode
LLM_TOP_N=10
# Parallel LLM calls (when enabled)
LLM_CONCURRENCY=2
# Per-call timeout in ms
LLM_TIMEOUT_MS=8000
