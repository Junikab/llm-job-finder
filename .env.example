# Copy to .env at repo root
# Single source of truth for local dev: this root .env file.
# Do not create apps/server/.env.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: custom API base URL (e.g., Azure/OpenRouter/proxy). Defaults to https://api.openai.com/v1 when unset
OPENAI_BASE_URL=
# Optional: set to 'debug' to print extra LLM logs (includes constructed prompt)
LLM_LOG=
PORT=5174
SCRAPER_HEADLESS=true
MAX_JOBS=40
MAX_PAGES=3
JORA_REGION=au

## Scoring mode: random | llm
# Default is random. To use LLM scoring, set SCORE_MODE=llm and provide OPENAI_API_KEY.
SCORE_MODE=random

## LLM configuration (applies when SCORE_MODE=llm)
# Parallel LLM calls (when enabled)
LLM_CONCURRENCY=2
# Per-call timeout in ms
LLM_TIMEOUT_MS=8000
# In-memory cache for LLM scoring results
# TTL in ms (default ~15 minutes)
LLM_CACHE_TTL_MS=900000
# Max number of cached entries (LRU eviction)
LLM_CACHE_MAX=200

# Enable CV enrichment (titles/topSkills/locationHints) with LLM even if SCORE_MODE!=llm
# Requires OPENAI_API_KEY. Default: false
LLM_ENRICH_CV=false

# Retry attempts for OpenAI calls (applies to 429, 5xx, and timeouts). Reasonable range: 1-5
LLM_RETRIES=2

# Max number of jobs to score with LLM per request (protects cost). Default 30
LLM_MAX_SCORE_JOBS=30

# Optional compact prompt customization to guide scoring without long examples
# Comma-separated or short phrases are fine; keep concise to save tokens
# Example:
# LLM_GOOD_TRAITS=junior, React/TypeScript, mentorship, remote, Sydney/NSW
# LLM_BAD_TRAITS=senior-only, backend-only Java, no UI, on-site far away
LLM_GOOD_TRAITS=
LLM_BAD_TRAITS=
