# Copy to .env at repo root
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PORT=5174
SCRAPER_HEADLESS=true
MAX_JOBS=40
MAX_PAGES=3
JORA_REGION=au

## Scoring mode: random | heuristic | llm
# default is random; llm replace-mode is wired and will call OpenAI when enabled
SCORE_MODE=heuristic

## LLM configuration
# LLM_MODE: off | rerank | replace
LLM_MODE=off
# Top-N for rerank mode
LLM_TOP_N=10
# Parallel LLM calls (when enabled)
LLM_CONCURRENCY=2
# Per-call timeout in ms
LLM_TIMEOUT_MS=8000

# Optional compact prompt customization to guide scoring without long examples
# Comma-separated or short phrases are fine; keep concise to save tokens
# Example:
# LLM_GOOD_TRAITS=junior, React/TypeScript, mentorship, remote, Sydney/NSW
# LLM_BAD_TRAITS=senior-only, backend-only Java, no UI, on-site far away
LLM_GOOD_TRAITS=
LLM_BAD_TRAITS=
